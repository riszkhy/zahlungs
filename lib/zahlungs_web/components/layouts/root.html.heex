<!DOCTYPE html>
<html lang="en" data-theme="light" class="h-full bg-green-50">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Zahlungs" suffix=" · Phoenix Framework">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}>
    </script>
  </head>
  <body class="flex flex-col h-full pt-16 text-base-content">
    <header
      class="fixed top-0 left-0 right-0 z-30 shadow-md bg-green-700 text-white"
      x-data="{ open: false }"
    >
      <div class="container mx-auto px-4 py-3 flex flex-wrap items-center justify-between gap-y-2">
        <a href={~p"/home"} title="Zahlungs Home" class="text-xl font-bold text-white">
          Zahlungs
        </a>

        <button
          type="button"
          class="md:hidden p-1 -mr-1 text-white"
          @click="open = !open"
          aria-label="Toggle menu"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="26"
            height="26"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
        </button>

        <nav class="w-full md:w-auto hidden md:block" x-bind:class="{ hidden: !open }">
          <.user_menu current_user={assigns[:current_user]} />
        </nav>
      </div>
    </header>

    {@inner_content}

    <footer class="py-3 mt-auto bg-gray-800">
      <div class="container max-w-4xl pb-4 mx-auto text-sm text-center text-gray-300">
        &copy; {DateTime.utc_now().year} Zahlungs
      </div>
    </footer>
  </body>
</html>
